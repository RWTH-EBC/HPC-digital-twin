ORION_LD_VERSION=1.1.0

# MongoDB variables
MONGO_DB_PORT=27017
MONGO_DB_VERSION=4.4.30

# Scorpio variables
SCORPIO_PORT=9090
SCORPIO_VERSION=2.1.21

# IoT Agent JSON Variables
# JSON_VERSION=1.25.0-distroless
JSON_VERSION=1.26.0
IOTA_NORTH_PORT=4041
IOTA_SOUTH_PORT=7896

# CrateDB
CRATE_VERSION=4.6.8

# Grafana
GRAFANA_VERSION=9.0.1

# QuantumLeap
QUANTUMLEAP_VERSION=0.8.1
