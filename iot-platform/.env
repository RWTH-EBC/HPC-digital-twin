# Deployment environment: selects the per-env InfluxDB database
# (influx_db_<env>) the influx_agent writes to. Valid values: itc, zih.
# MUST match DEPLOYMENT_ENV in backend/.env and frontend/.env.
DEPLOYMENT_ENV=itc