# Deployment Environment Configuration
# Choose between: "itc" and "zih"
DEPLOYMENT_ENV=zih

# Timestep for agents (in seconds)
TIMESTEP=60

# Run in real-time mode (1 = true, 0 = false)
RUN_LIVE=1

# State saver configuration (only for ITC deployments)
# Hours between FMU state saves (default: 24 for daily saves)
STATE_SAVE_INTERVAL_HOURS=24

# Coordinator API URL for state saver
COORDINATOR_URL=http://localhost:8000